/*
 * Nextflow configuration for dengue-africa training pipeline.
 * Supports both VAE (--model vae) and Transformer (--model transformer).
 *
 * Profiles:
 *   local     — single machine, development/testing
 *   spacehpc  — PBS cluster at spacehpc.esa.int
 *
 * To add a new cluster, copy the spacehpc profile block and adjust the
 * executor, queue, clusterOptions, and params accordingly.
 *
 * Usage:
 *   nextflow run nextflow/main.nf -profile spacehpc \
 *       --model transformer --ddp --num_gpus 4 ...
 */

// ── Default parameters (machine-independent) ─────────────────────────────────
params {
    // Paths — override in your profile or on the CLI
    project_root   = null   // required: absolute path to the dengue-africa repo checkout
    data_root      = null   // defaults to <project_root>/data if null
    outdir         = null   // defaults to <project_root>/checkpoints if null

    // External data — required only when --add_sm / --add_lc is set
    sm_data_path   = null   // root dir of SM_[A|D]_YYYYMMDD.tif files
    lc_data_path   = null   // root dir of annual MCD12Q1 GeoTIFF files

    // Data prep
    prepare_data   = false

    // Model selection
    model              = 'vae'   // 'vae' or 'transformer'

    // Shared training hyperparameters
    batch_size         = 4
    num_epochs         = 100
    num_workers        = 8
    learning_rate      = 1e-3
    patience           = 10
    train_split        = 0.8
    loss_fn            = 'mse'
    grad_accum_steps   = 1
    cleanup_every      = 100

    // VAE-specific
    beta_kl            = 0.01
    latent_channels    = 4
    layers_per_block   = 2
    norm_num_groups    = 32
    use_kl             = false

    // Transformer-specific
    med_in_ch                = 18
    swin_model               = 'swin_tiny_patch4_window7_224.ms_in1k'
    use_titok                = false
    titok_backbone           = 'vit_base_patch16_224.mae'
    titok_num_latent_tokens  = 32

    // Distributed training
    ddp        = false
    num_gpus   = 1

    // Branches
    add_sm     = false
    add_lc     = false
}

// ── Profiles ──────────────────────────────────────────────────────────────────
profiles {

    local {
        params.project_root = "${System.getenv('HOME')}/Riccardo/projects/dengue-africa"
        params.data_root    = "${params.project_root}/data"
        params.outdir       = "${params.project_root}/checkpoints"

        executor.queueSize  = 1
        process.executor    = 'local'
    }

    spacehpc {
        // ── Cluster paths (specific to spacehpc.esa.int) ──────────────────
        params.project_root = '/lustre/projects/1001/rdercole/dengue-africa'
        params.data_root    = "${params.project_root}/data"
        params.outdir       = "${params.project_root}/checkpoints"
        params.sm_data_path = '/lustre/projects/1000/WorldSAR/soil_moisture'
        params.lc_data_path = '/lustre/projects/1000/WorldSAR/land_cover'

        // ── PBS scheduler ──────────────────────────────────────────────────
        executor.queueSize = 10

        process {
            executor = 'pbs'

            withLabel: 'cpu' {
                queue          = 'cpu_std'
                clusterOptions = '-P hpc-prj-1001 -l select=1:ncpus=8:mem=32gb -l walltime=04:00:00'
            }

            withLabel: 'gpu' {
                // gpu4_std: 4×H100 per node, 96 CPUs, 700 GB RAM
                queue          = 'gpu4_std'
                clusterOptions = "-P hpc-prj-1001 -l select=1:ncpus=96:ngpus=${params.num_gpus}:mem=700gb -l walltime=24:00:00"
            }
        }

        // ── Runtime environment ────────────────────────────────────────────
        env {
            PYTHONPATH = "${params.project_root}/src:\${PYTHONPATH:-}"
            // Add user-local bin and JDK to PATH (adjust for your account)
            PATH       = "\$HOME/.local/bin:\$HOME/bin:\$HOME/jdk-17.0.12/bin:\${PATH:-}"
            // Expose bundled NVIDIA libs (cuDNN, NCCL, cuBLAS, etc.)
            LD_LIBRARY_PATH = [
                "${params.project_root}/.venv/lib/python3.11/site-packages/nvidia/cudnn/lib",
                "${params.project_root}/.venv/lib/python3.11/site-packages/nvidia/nccl/lib",
                "${params.project_root}/.venv/lib/python3.11/site-packages/nvidia/cublas/lib",
                "${params.project_root}/.venv/lib/python3.11/site-packages/nvidia/cuda_runtime/lib",
                "${params.project_root}/.venv/lib/python3.11/site-packages/nvidia/nvjitlink/lib",
                "\${LD_LIBRARY_PATH:-}",
            ].join(':')
            HDF5_USE_FILE_LOCKING = "FALSE"
            HF_HUB_OFFLINE        = "1"
            HF_HOME               = "${params.project_root}/.cache/huggingface"
            NCCL_IB_DISABLE       = "1"
            NCCL_SOCKET_IFNAME    = "lo"
        }
    }
}
